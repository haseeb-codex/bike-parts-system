# Server
NODE_ENV=development
PORT=5000
API_BASE_URL=http://localhost:5000

# Database
MONGODB_URI=mongodb://localhost:27017/bike_parts_system
MONGODB_USER=
MONGODB_PASSWORD=

# JWT
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRE=7d

# Admin User (for initialization)
ADMIN_EMAIL=admin@bikepartsystem.com
ADMIN_PASSWORD=Change@123

# Email Service (optional - for future)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Application
APP_NAME=Bike Spare Parts Management System
APP_VERSION=1.0.0
LOG_LEVEL=debug
